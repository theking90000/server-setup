# justfile

# Liste les commandes par défaut
default:
    @just --list

# Met à jour la librairie publique vers le dernier commit
update-lib:
    nix flake update infra

# Vérifie les sorties du flake puis force l'évaluation complète de chaque nœud
check:
    nix flake check --all-systems
    colmena eval --impure -E '{ nodes, ... }: builtins.mapAttrs (_: node: node.config.system.build.toplevel.drvPath) nodes'

# Génère la configuration Wireguard
generate-mesh:
    @echo "Génération du réseau Mesh..."
    generate-mesh

# Télécharge les configurations matérielles des VPS
adopt-hardware:
    @echo "Récupération de la configuration matérielle..."
    adopt-hardware

# Exporte les clés SSH pour le cert-syncer
export-keys:
    @echo "Exportation des clés SSH..."
    export-ssh-key
    generate-key

# Prépare les fichiers locaux sans déployer
prepare: generate-mesh adopt-hardware export-keys

# Prépare puis déploie
deploy target="": prepare
    @echo "Lancement de Colmena..."
    colmena apply {{ if target == "" { "" } else { "--on " + target } }}
